from pydantic import BaseModel, EmailStr
from typing import Optional, List
from datetime import datetime, date


class UserBase(BaseModel):
    entity_id: str
    applicant_name: str
    email: Optional[str] = None
    phone: Optional[str] = None


class UserCreate(UserBase):
    kyc_status: Optional[str] = 'pending'
    kyc_document_url: Optional[str] = None
    i_360_score: Optional[float] = 0.0
    i_not_score: Optional[float] = 0.0
    suspicious_score: Optional[float] = 0.0
    risk_level: Optional[str] = 'low'
    is_blacklisted: Optional[bool] = False
    blacklist_reason: Optional[str] = None
    account_status: Optional[str] = 'active'
    address: Optional[str] = None
    city: Optional[str] = None
    state: Optional[str] = None
    country: Optional[str] = 'India'
    postal_code: Optional[str] = None
    date_of_birth: Optional[date] = None


class UserUpdate(BaseModel):
    applicant_name: Optional[str] = None
    email: Optional[str] = None
    phone: Optional[str] = None
    kyc_status: Optional[str] = None
    kyc_verified_at: Optional[datetime] = None
    kyc_document_url: Optional[str] = None
    i_360_score: Optional[float] = None
    i_not_score: Optional[float] = None
    suspicious_score: Optional[float] = None
    risk_level: Optional[str] = None
    is_blacklisted: Optional[bool] = None
    blacklist_reason: Optional[str] = None
    blacklisted_at: Optional[datetime] = None
    account_status: Optional[str] = None
    address: Optional[str] = None
    city: Optional[str] = None
    state: Optional[str] = None
    country: Optional[str] = None
    postal_code: Optional[str] = None
    date_of_birth: Optional[date] = None
    last_login_at: Optional[datetime] = None


class UserRead(UserBase):
    id: int
    kyc_status: str
    kyc_verified_at: Optional[datetime] = None
    kyc_document_url: Optional[str] = None
    i_360_score: float
    i_not_score: float
    suspicious_score: float
    risk_level: str
    is_blacklisted: bool
    blacklist_reason: Optional[str] = None
    blacklisted_at: Optional[datetime] = None
    account_status: str
    address: Optional[str] = None
    city: Optional[str] = None
    state: Optional[str] = None
    country: str
    postal_code: Optional[str] = None
    date_of_birth: Optional[date] = None
    created_at: datetime
    updated_at: datetime
    last_login_at: Optional[datetime] = None

    class Config:
        from_attributes = True


class UserListResponse(BaseModel):
    total: int
    items: List[UserRead]

    class Config:
        from_attributes = True


# UserSanctionMatch Schemas
class UserSanctionMatchBase(BaseModel):
    user_id: int
    match_found: Optional[bool] = None
    match_confidence: Optional[float] = None
    matched_entity_name: Optional[str] = None


class UserSanctionMatchCreate(UserSanctionMatchBase):
    time: Optional[int] = None
    diff: Optional[int] = None


class UserSanctionMatchRead(UserSanctionMatchBase):
    match_id: int
    checked_at: datetime
    time: Optional[int] = None
    diff: Optional[int] = None

    class Config:
        from_attributes = True
